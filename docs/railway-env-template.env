# =====================================================================
# Soulmate9 — Railway 环境变量完整清单（模板，无真实密钥）
# =====================================================================
# 用途：
#   1. 核对旧项目 zucchini-communication 的 Variables 是否齐全
#   2. 新项目 successful-trust 需要"从零"配置全部变量（Railway 项目间不共享）
#   3. 真实数值请从旧项目 Variables → Raw Editor 复制，或从你自己的密钥管理工具找
#
# 用法：Railway 项目 → 服务 → Variables → Raw Editor → 粘贴（填好真实值后）→ Save
# =====================================================================

# ── Supabase Auth（浏览器端登录用，必须 NEXT_PUBLIC_ 前缀才会被打进客户端包）──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase 业务数据（Coze 代理，服务端用，不要加 NEXT_PUBLIC_）──
COZE_SUPABASE_URL=
COZE_SUPABASE_ANON_KEY=
COZE_SUPABASE_SERVICE_ROLE_KEY=
COZE_SUPABASE_DB_URL=

# ── 管理员邮箱白名单（生产环境用，逗号分隔）──
ALLOWED_ADMIN_EMAILS=

# ── Coze SDK / LLM 主路由 ──
COZE_API_KEY=
COZE_API_BASE=https://api.coze.cn
COZE_BOT_ID=
COZE_DEFAULT_MODEL=doubao-seed-2-0-pro-250715
COZE_LITE_MODEL=doubao-seed-2-0-lite-250715
COZE_MINI_MODEL=doubao-seed-2-0-mini-250715
COZE_INTEGRATION_BASE_URL=https://integration.coze.cn
COZE_INTEGRATION_MODEL_BASE_URL=https://integration.coze.cn
COZE_WORKLOAD_IDENTITY_API_KEY=

# ── 对象存储（R2 / OSS，用于图片等媒体）──
COZE_BUCKET_ENDPOINT_URL=
COZE_BUCKET_NAME=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
SUPABASE_STORAGE_BUCKET=portraits

# ── LLM 兜底（Claude，可选）──
ANTHROPIC_API_KEY=
CLAUDE_FALLBACK_MODEL=claude-3-5-haiku-20241022

# ── 本地 Llama（可选，情绪检测）──
LOCAL_LLAMA_BASE_URL=
LOCAL_LLAMA_MODEL=llama3.1:8b

# ── RunPod FLUX 图片生成 ──
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_POLL_TIMEOUT_MS=360000
RUNPOD_POLL_INTERVAL_MS=3000

# ── Stripe 订阅支付 ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_UNLIMITED=

# ── 加密货币支付（NOWPayments，可选备选通道）──
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# ── 限流（Upstash Redis，无则退化为单实例内存限流）──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron 鉴权（自己生成：openssl rand -hex 32）──
CRON_SECRET=

# ── Sentry 错误监控（可选，不填则 sentry.ts 自动 no-op）──
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05
SENTRY_RELEASE=

# ── PostHog 埋点（可选）──
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Resend 邮件（强烈建议开）──
RESEND_API_KEY=
RESEND_FROM_EMAIL=
EMAIL_FROM=
ADMIN_ALERT_EMAIL=

# ── Web Push 通知（可选）──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@soulmateai.shop

# ── Google Analytics（可选）──
NEXT_PUBLIC_GA_ID=

# ── 调试路由开关（生产环境必须 false，否则暴露 DB schema / 密钥前缀）──
ENABLE_DEBUG_ROUTES=false

# ── 日志级别 ──
LOG_LEVEL=info

# ── 应用/运行时配置 ──
NEXT_PUBLIC_APP_URL=https://soulmateai.shop
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
