# =============================
# SoulMate AI — Environment Variables
# =============================
# Copy to .env.local for local dev, set in Vercel project settings for prod.
# All keys listed below are required unless marked OPTIONAL.

# ── Supabase Auth (public, used by browser + server to verify JWT) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase Data (private, Coze-proxied; service_role via Python proxy) ──
COZE_SUPABASE_URL=
COZE_SUPABASE_SERVICE_ROLE_KEY=
COZE_SUPABASE_DB_URL=

# ── Auth (production-only admin email fallback; NOT used in dev) ──
# Comma-separated admin emails; ignored in NODE_ENV=production.
ALLOWED_ADMIN_EMAILS=

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── RunPod FLUX image generation ──
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
SUPABASE_STORAGE_BUCKET=portraits

# ── LLM (Coze) ──
COZE_API_KEY=
COZE_API_BASE=https://api.coze.cn

# ── Crypto payment ──
# See src/lib/crypto-config.ts for full config
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# ── Rate limit (Upstash Redis) ──
# Required for production rate limiting; without these, falls back to in-memory
# (single-instance only — Vercel serverless will not enforce global limits).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Email (Resend) — OPTIONAL, falls back to Supabase default SMTP ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Sentry error monitoring — OPTIONAL ──
# Without these, src/lib/sentry.ts becomes no-op and logger.error() only
# emits JSON logs to stdout.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Debug routes — DANGER ──
# Set to "true" to enable /api/admin/db-debug, /api/admin/key-debug,
# /api/admin/refresh-portraits, /api/admin/upload-scenes. These are
# additionally protected by requireAdmin('superadmin') in code.
ENABLE_DEBUG_ROUTES=

# ── Logging ──
LOG_LEVEL=debug
