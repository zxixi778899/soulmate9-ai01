# =============================
# SoulMate AI — Environment Variables
# =============================
# Copy to .env.local for local dev, set in Railway/Vercel project settings for prod.
# Required unless marked OPTIONAL. Keep this file in sync with `src/` —
# run: grep -rohE "process\.env\.[A-Z_0-9]+" src | sort -u
# whenever you add a new process.env.* reference, and add it here.

# ── Supabase Auth (public project — used by browser + server to verify JWT) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase Data (second "Coze" project — service-role access for app data) ──
# NOTE: COZE_SUPABASE_ANON_KEY (no NEXT_PUBLIC_ prefix) is REQUIRED server-side
# by src/storage/database/supabase-client.ts — it is NOT the same variable as
# NEXT_PUBLIC_COZE_SUPABASE_ANON_KEY (browser-exposed). Both must be set.
NEXT_PUBLIC_COZE_SUPABASE_URL=
NEXT_PUBLIC_COZE_SUPABASE_ANON_KEY=
COZE_SUPABASE_URL=
COZE_SUPABASE_ANON_KEY=
COZE_SUPABASE_SERVICE_ROLE_KEY=
COZE_SUPABASE_DB_URL=

# ── Auth (production-only admin email fallback; ignored when NODE_ENV=production) ──
# Comma-separated admin emails, used only in non-production for local testing.
ALLOWED_ADMIN_EMAILS=

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs — used by pricing page + webhook to resolve tier from Stripe price.
STRIPE_PRO_PRICE_ID=
STRIPE_UNLIMITED_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_UNLIMITED_PRICE_ID=
# Legacy aliases still read by some code paths — keep equal to the above until fully migrated.
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_UNLIMITED=

# ── RunPod FLUX image generation ──
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
# Alias accepted for RUNPOD_API_KEY in some clients — set one or the other.
RUNPOD_COMFYUI_API_KEY=
SUPABASE_STORAGE_BUCKET=portraits

# ── RunPod vLLM (dedicated NSFW-capable text model, OPTIONAL) ──
# When unset, NSFW chat falls back further down the chain — see llm-service.ts.
RUNPOD_VLLM_URL=
RUNPOD_VLLM_API_KEY=
RUNPOD_VLLM_MODEL=

# ── LLM primary provider: Coze (Doubao) ──
# Auth: workload-identity credentials exchanged for a short-lived JWT.
# This is the ONLY pair actually read by src/lib/coze-auth.ts — the old
# COZE_API_KEY variable name is NOT used anywhere in the codebase, do not rely on it.
COZE_WORKLOAD_IDENTITY_API_KEY=
COZE_WORKLOAD_IDENTITY_CLIENT_SECRET=
# OPTIONAL overrides — defaults to https://api.coze.cn / https://integration.coze.cn
COZE_AUTH_BASE_URL=
COZE_INTEGRATION_BASE_URL=
COZE_INTEGRATION_MODEL_BASE_URL=
# OPTIONAL — Coze project environment tag, if used by your Coze workspace setup.
COZE_PROJECT_ENV=

# ── LLM fallback chain (in order): Anthropic Claude -> Together AI -> local Llama ──
ANTHROPIC_API_KEY=
CLAUDE_FALLBACK_MODEL=claude-3-5-haiku-20241022
TOGETHER_API_KEY=
TOGETHER_MODEL=
TOGETHER_FAST_MODEL=
LOCAL_LLAMA_BASE_URL=
LOCAL_LLAMA_MODEL=

# ── Object storage (Coze-managed bucket, used alongside/instead of S3) ──
COZE_BUCKET_ENDPOINT_URL=
COZE_BUCKET_NAME=

# ── Crypto payment ──
CRYPTO_WALLET_BTC=
CRYPTO_WALLET_ETH=
CRYPTO_WALLET_USDT=
# See src/lib/crypto-config.ts for full NOWPayments config (OPTIONAL — enables
# automated on-chain verification instead of manual admin confirmation).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# ── Rate limit (Upstash Redis) ──
# Required for production rate limiting; without these, falls back to in-memory
# (single-instance only — Vercel/Railway serverless will not enforce global limits).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Email (Resend) — OPTIONAL, falls back to Supabase default SMTP ──
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_ALERT_EMAIL=

# ── Web Push notifications — OPTIONAL ──
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── Cron job auth ──
# Shared secret required by all /api/cron/* routes (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=

# ── Analytics — OPTIONAL ──
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
POSTHOG_API_KEY=
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=
POSTHOG_FLUSH_INTERVAL=

# ── Sentry error monitoring — OPTIONAL ──
# Without these, src/lib/sentry.ts becomes no-op and logger.error() only
# emits JSON logs to stdout.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# ── App URLs / build metadata ──
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_COMMIT_SHA=

# ── Debug routes — DANGER ──
# Set to "true" to enable /api/admin/db-debug, /api/admin/key-debug,
# /api/admin/refresh-portraits, /api/admin/upload-scenes. These are
# additionally protected by requireAdmin('superadmin') in code.
ENABLE_DEBUG_ROUTES=

# ── Logging ──
LOG_LEVEL=debug
